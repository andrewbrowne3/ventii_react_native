# Copy to backend/.env on the server and fill in real values.
# docker-compose.prod.yml reads this file.

DEBUG=0

# Generate a long random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

DJANGO_ALLOWED_HOSTS=ventii.andrewbrowne.org,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://ventii.andrewbrowne.org

# Lock CORS to the domain in production.
CORS_ALLOW_ALL_ORIGINS=0
CORS_ALLOWED_ORIGINS=https://ventii.andrewbrowne.org

# Set to 1 on first boot to load demo data (demo@ventii.app / demo12345),
# then set back to 0 so it doesn't reseed on every restart.
SEED=1

# ── Paid ticketing (Phase 4). Leave unset until you're ready — checkout then
#    returns "Payment integration coming soon". Use TEST keys (sk_test_…) first.
#    Real values go here on the server only; never commit them. ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Publishable key (pk_…) is used by the app, not the server.

# ── QR pass signing. Optional — falls back to DJANGO_SECRET_KEY if unset.
#    Set a long random value to rotate QR signing independently. ──
QR_SIGNING_KEY=
